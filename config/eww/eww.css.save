/* ═══════════════════════════════════════════════════════════════════
   NC2077 // EWW UNIFIED CSS v6
   BAR: Cyberpunk 2077 — đen thẫm + cyan neon + đa màu accent
   CC:  Military terminal phosphor green
   Font: JetBrainsMono Nerd Font
   ═══════════════════════════════════════════════════════════════════ */

/* ── GTK GLOBAL RESET — safe cho EWW ─────────────────────────── */
/* KHÔNG dùng all:unset — nó phá rendering pipeline của GTK/EWW  */
* {
  font-family: "JetBrainsMono Nerd Font", "JetBrains Mono",
               "Iosevka Nerd Font", "Hack Nerd Font", monospace;
  font-size:   12px;
  border:      none;
  outline:     none;
  padding:     0;
  margin:      0;
  min-height:  0;
}
button {
  background:  transparent;
  border:      none;
  border-radius: 0;
  padding:     0;
  margin:      0;
}

/* ═══════════════════════════════════════════════════════════════════
   BAR
   ═══════════════════════════════════════════════════════════════════ */

/* ── BAR ROOT ───────────────────────────────────────────────────── */
.bar-root {
  /* Dark deep-sea base — bộ khác với CC */
  background-color:  rgba(1, 6, 12, 0.97);
  border-radius:     4px;

  /* Scanline — dòng kẻ ngang mờ kiểu CRT phosphor */
  background-image: repeating-linear-gradient(
    180deg,
    transparent                   0px,
    transparent                   2px,
    rgba(0, 230, 255, 0.022)      2px,
    rgba(0, 230, 255, 0.022)      4px
  );

  /* Viền: top sáng = neon edge, bottom = shadow line, 2 bên = frame */
  border-top:    2px solid rgba(0, 230, 255, 0.75);
  border-bottom: 1px solid rgba(255, 0, 60,  0.40);
  border-left:   1px solid rgba(0, 230, 255, 0.18);
  border-right:  1px solid rgba(0, 230, 255, 0.18);

  /* Box glow kép: cyan trên, đỏ dưới */
  box-shadow:
    0  0 0 1px rgba(0, 230, 255, 0.04),
    0  2px 0 0  rgba(255, 0,  60, 0.25),
    0  0 40px   rgba(0, 230, 255, 0.07),
    0  8px 32px rgba(0, 0, 0,   0.95);

  min-height: 40px;
  padding:    0;
}

/* ── LEFT ZONE ──────────────────────────────────────────────────── */
.bar-left { min-height: 40px; }

/* MODE PILL — bấm mở CC */
button.bar-mode {
  background:    #00e6ff;
  padding:       0 14px 0 12px;
  min-height:    40px;
  border-right:  2px solid rgba(0, 100, 130, 0.9);
  border-radius: 0;

  /* Bevel trong */
  box-shadow: inset 0 -2px 8px rgba(0, 0, 0, 0.4),
              inset 0  1px 0   rgba(255,255,255,0.3);
}
button.bar-mode:hover {
  background: #33eeff;
  box-shadow: 0 0 20px rgba(0,230,255,0.55),
              inset 0 -2px 8px rgba(0,0,0,0.3);
}
.bar-mode-dot {
  font-size: 8px;
  color:     rgba(0,20,30,0.7);
}
.bar-mode-txt {
  font-size:     9px;
  font-weight:   900;
  letter-spacing:2px;
  color:         #010a10;
}

/* CORNER BRACKETS */
.bar-corner { font-size: 22px; color: rgba(0, 230, 255, 0.18); }
.bar-corner-l { padding: 0 0 0 2px; }
.bar-corner-r { padding: 0 2px 0 0; }

/* WORKSPACES */
.bar-ws-wrap {
  padding:      0;
  border-right: 1px solid rgba(0, 230, 255, 0.08);
  min-height:   40px;
}
button.bar-ws {
  font-size:    16px;
  color:        rgba(255, 255, 255, 0.09);
  padding:      0 7px;
  min-height:   40px;
  min-width:    28px;
  border-bottom:2px solid transparent;
}
button.bar-ws:hover {
  color:        rgba(0, 230, 255, 0.5);
  background:   rgba(0, 230, 255, 0.04);
  border-bottom:2px solid rgba(0, 230, 255, 0.3);
}
button.bar-ws.ws-on {
  color:        #00e6ff;
  border-bottom:2px solid #00e6ff;
  background:   rgba(0, 230, 255, 0.07);
  text-shadow:
    0 0 8px  rgba(0, 230, 255, 1.0),
    0 0 22px rgba(0, 230, 255, 0.5);
}

/* TITLE */
.bar-div        { color: rgba(0,230,255,0.10); font-size: 14px; padding: 0 3px; }
.bar-title-box  { padding: 0 8px; min-height: 40px; border-right: 1px solid rgba(0,230,255,0.06); }
.bar-title-arrow{ font-size: 9px; color: rgba(0,230,255,0.28); }
.bar-title      { font-size: 10px; color: rgba(255,255,255,0.22); letter-spacing: 0.5px; }

/* ── CENTER — CLOCK ─────────────────────────────────────────────── */
.bar-clock-box {
  min-height:   40px;
  padding:      0 24px;

  /* Khung đặc biệt — 2 đường viền dọc glow mạnh */
  border-left:  2px solid rgba(0, 230, 255, 0.55);
  border-right: 2px solid rgba(0, 230, 255, 0.55);

  /* Nền gradient giữa — halo effect */
  background: linear-gradient(
    90deg,
    transparent                  0%,
    rgba(0, 230, 255, 0.04)     25%,
    rgba(0, 230, 255, 0.07)     50%,
    rgba(0, 230, 255, 0.04)     75%,
    transparent                 100%
  );

  box-shadow:
    -3px 0 20px rgba(0, 230, 255, 0.20),
     3px 0 20px rgba(0, 230, 255, 0.20);
}
.bar-clock-decor {
  font-size:   13px;
  color:       rgba(0, 230, 255, 0.22);
  letter-spacing: 0;
}
.bar-clock-h, .bar-clock-m {
  font-size:    18px;
  font-weight:  900;
  letter-spacing: 2px;
  color:        #00e6ff;
  text-shadow:
    0 0 6px  rgba(0, 230, 255, 1.0),
    0 0 18px rgba(0, 230, 255, 0.6),
    0 0 40px rgba(0, 230, 255, 0.2);
}
.bar-clock-s {
  font-size:    14px;
  font-weight:  700;
  color:        rgba(0, 230, 255, 0.5);
  letter-spacing: 1px;
  text-shadow:  0 0 8px rgba(0,230,255,0.4);
}
.bar-clock-sep {
  font-size:  16px;
  color:      rgba(0, 230, 255, 0.30);
  padding:    0 1px;
}
.bar-date {
  font-size:    10px;
  color:        rgba(0, 230, 255, 0.35);
  letter-spacing: 1.5px;
}

/* ── RIGHT ZONE ─────────────────────────────────────────────────── */
.bar-right { min-height: 40px; }

/* MEDIA STRIP */
.bar-media {
  padding:      0 8px;
  border-right: 1px solid rgba(0,230,255,0.07);
  min-height:   40px;
}
.bar-media-ico  { font-size: 13px; color: rgba(57,255,20,0.65); }
.bar-media-txt  { font-size: 10px; color: rgba(57,255,20,0.60); letter-spacing: 0.5px; }
button.bar-media-btn {
  font-family: inherit;
  font-size:   12px;
  color:       rgba(57,255,20,0.5);
  padding:     0 4px;
}
button.bar-media-btn:hover { color: #39ff14; background: rgba(57,255,20,0.07); }

/* CHIPS — khối stat dọc, mỗi cái màu khác */
.bar-chip {
  padding:      0 11px;
  min-height:   40px;
  border-left:  1px solid rgba(255,255,255,0.04);
  border-bottom:2px solid transparent;  /* override per-chip */
}
.bar-chip:hover { background: rgba(255,255,255,0.025); }

.chip-ico { font-size: 13px; }
.chip-val { font-size: 11px; font-weight: 700; }
.chip-lbl { font-size: 6px;  letter-spacing: 1.5px; color: rgba(255,255,255,0.18); }

/* Per-chip accent colors + bottom border glow */
.r-cpu  {
  border-bottom: 2px solid rgba(255, 0,  60, 0.55);
  background: linear-gradient(180deg, transparent 55%, rgba(255,0,60,0.06) 100%);
}
.r-ram  {
  border-bottom: 2px solid rgba(0, 230, 255, 0.50);
  background: linear-gradient(180deg, transparent 55%, rgba(0,230,255,0.06) 100%);
}
.r-temp {
  border-bottom: 2px solid rgba(255, 119, 0, 0.50);
  background: linear-gradient(180deg, transparent 55%, rgba(255,119,0,0.06) 100%);
}
.r-bat  {
  border-bottom: 2px solid rgba(57, 255, 20, 0.45);
  background: linear-gradient(180deg, transparent 55%, rgba(57,255,20,0.06) 100%);
}
.r-cpu:hover  { border-bottom: 2px solid rgba(255,0,60,0.9);   box-shadow: inset 0 -4px 12px rgba(255,0,60,0.10); }
.r-ram:hover  { border-bottom: 2px solid rgba(0,230,255,0.9);  box-shadow: inset 0 -4px 12px rgba(0,230,255,0.08); }
.r-temp:hover { border-bottom: 2px solid rgba(255,119,0,0.9);  }
.r-bat:hover  { border-bottom: 2px solid rgba(57,255,20,0.9);  }

/* Chip value colors */
.cv-red    { color: #ff003c; text-shadow: 0 0 8px rgba(255,0,60,0.7); }
.cv-cyan   { color: #00e6ff; text-shadow: 0 0 8px rgba(0,230,255,0.7); }
.cv-orange { color: #ff7700; text-shadow: 0 0 8px rgba(255,119,0,0.7); }
.cv-green  { color: #39ff14; text-shadow: 0 0 8px rgba(57,255,20,0.7); }

/* NET PILL */
button.bar-net {
  padding:       0 12px;
  min-height:    40px;
  border-left:   1px solid rgba(255,255,255,0.04);
  border-radius: 0;
}
.bar-net-ico { font-size: 14px; }
.bar-net-txt { font-size: 9px; letter-spacing: 1px; }

button.net-on  { color: rgba(57,255,20,0.70); border-bottom: 2px solid rgba(57,255,20,0.40); }
button.net-off { color: rgba(255,0,60,0.60);  border-bottom: 2px solid rgba(255,0,60,0.35); }
button.net-on:hover  { background: rgba(57,255,20,0.06); color: #39ff14; }
button.net-off:hover { background: rgba(255,0,60,0.06);  color: #ff003c; }

/* VOLUME */
button.bar-vol {
  padding:       0 10px;
  min-height:    40px;
  border-left:   1px solid rgba(255,255,255,0.04);
  border-bottom: 2px solid rgba(255, 45, 155, 0.45);
  background:    linear-gradient(180deg, transparent 55%, rgba(255,45,155,0.06) 100%);
  border-radius: 0;
  color:         rgba(255, 45, 155, 0.75);
}
button.bar-vol:hover {
  background: rgba(255,45,155,0.10);
  border-bottom: 2px solid rgba(255,45,155,0.9);
  color: #ff2d9b;
}
button.bar-vol.vol-muted { color: rgba(255,45,155,0.25); }
.bar-vol-ico { font-size: 14px; }
.bar-vol-val { font-size: 10px; letter-spacing: 1px; }

/* POWER */
button.bar-power {
  font-size:    15px;
  color:        rgba(255, 0, 60, 0.7);
  padding:      0 16px;
  min-height:   40px;
  border-left:  1px solid rgba(255,0,60,0.20);
  background:   rgba(255,0,60,0.04);
  text-shadow:  0 0 8px rgba(255,0,60,0.55);
}
button.bar-power:hover {
  color:      #ff003c;
  background: rgba(255,0,60,0.18);
  text-shadow:
    0 0 12px rgba(255,0,60,1.0),
    0 0 30px rgba(255,0,60,0.5);
  box-shadow: inset 0 0 20px rgba(255,0,60,0.15);
}

/* ═══════════════════════════════════════════════════════════════════
   CONTROL CENTER
   ═══════════════════════════════════════════════════════════════════ */

.cc-root {
  background:    #010a02;
  border-top:    2px solid rgba(0,255,65,0.75);
  border-right:  1px solid rgba(0,255,65,0.14);
  border-bottom: 1px solid rgba(0,255,65,0.08);
  border-left:   1px solid rgba(0,255,65,0.14);
  box-shadow:
    0 0 0 1px rgba(0,255,65,0.03),
    0 0 30px rgba(0,255,65,0.08),
    0 20px 60px rgba(0,0,0,0.95),
    inset 0 0 60px rgba(0,255,65,0.015);
}

.cc-header {
  padding:       9px 14px 8px;
  background:    linear-gradient(90deg, rgba(0,255,65,0.06) 0%, transparent 60%);
  border-bottom: 1px solid rgba(0,255,65,0.1);
}
.cc-title {
  font-size:    11px;
  font-weight:  900;
  color:        #00ff41;
  letter-spacing: 5px;
  text-shadow:
    0 0 6px  rgba(0,255,65,1),
    0 0 18px rgba(0,255,65,0.6),
    0 0 40px rgba(0,255,65,0.2);
}
.cc-time {
  font-size:    10px;
  font-weight:  600;
  color:        rgba(0,255,65,0.6);
  letter-spacing: 2px;
}
.cc-div {
  min-height: 1px;
  background: linear-gradient(90deg,
    transparent 0%, rgba(0,255,65,0.05) 8%,
    rgba(0,255,65,0.3) 50%, rgba(0,255,65,0.05) 92%, transparent 100%);
}

/* SECTION LABELS */
.section-label-box { padding: 8px 14px 3px; }
.section-label {
  font-size:    8px;
  font-weight:  700;
  color:        rgba(0,255,65,0.6);
  letter-spacing: 4px;
}

/* MEDIA */
.media-wrap {
  min-height:         84px;
  background-color:   #010802;
  background-size:    cover;
  background-position:center;
}
.media-overlay {
  min-height: 84px;
  padding:    10px 14px 9px;
  background: linear-gradient(0deg,
    rgba(1,10,2,0.97) 0%, rgba(1,10,2,0.72) 55%, rgba(1,10,2,0.2) 100%);
}
.media-title  { font-size: 12px; font-weight: 700; color: rgba(210,255,220,0.94); letter-spacing: 0.5px; }
.media-artist { font-size: 9px;  color: rgba(0,255,65,0.7); letter-spacing: 2px; margin-bottom: 7px; }
.media-controls { margin-top: 3px; }
button.media-btn {
  font-family: inherit;
  background:  rgba(0,255,65,0.06);
  border:      1px solid rgba(0,255,65,0.16);
  color:       rgba(0,255,65,0.65);
  font-size:   12px;
  padding:     3px 13px;
}
button.media-btn:hover {
  background:   rgba(0,255,65,0.14);
  border-color: rgba(0,255,65,0.5);
  color:        #00ff41;
  box-shadow:   0 0 10px rgba(0,255,65,0.25);
}
button.media-btn.play {
  color:        #00ff41;
  font-size:    15px;
  border-color: rgba(0,255,65,0.4);
  background:   rgba(0,255,65,0.11);
  box-shadow:   0 0 8px rgba(0,255,65,0.18);
}

/* TOGGLES */
.toggles-row { padding: 6px 10px 8px; }
button.toggle-btn {
  padding:   9px 4px 7px;
  background:rgba(255,255,255,0.025);
  border:    1px solid rgba(255,255,255,0.06);
  min-width: 56px;
}
button.toggle-btn:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); }

.t-icon  { font-size: 16px; color: rgba(255,255,255,0.42); }
.t-label { font-size: 7px;  color: rgba(255,255,255,0.35); letter-spacing: 1px; }

button.t-on {
  background:  rgba(0,255,65,0.09);
  border-color:rgba(0,255,65,0.35);
  box-shadow:  0 0 8px rgba(0,255,65,0.09), inset 0 1px 0 rgba(0,255,65,0.3);
}
button.t-on .t-icon  { color: #00ff41; text-shadow: 0 0 8px rgba(0,255,65,0.9), 0 0 20px rgba(0,255,65,0.4); }
button.t-on .t-label { color: rgba(0,255,65,0.9); }

button.t-blue {
  background:  rgba(79,195,247,0.09);
  border-color:rgba(79,195,247,0.35);
  box-shadow:  0 0 8px rgba(79,195,247,0.09), inset 0 1px 0 rgba(79,195,247,0.3);
}
button.t-blue .t-icon  { color: #4fc3f7; text-shadow: 0 0 8px rgba(79,195,247,0.9); }
button.t-blue .t-label { color: rgba(79,195,247,0.9); }

button.t-red {
  background:  rgba(255,0,68,0.09);
  border-color:rgba(255,0,68,0.35);
  box-shadow:  0 0 8px rgba(255,0,68,0.09), inset 0 1px 0 rgba(255,0,68,0.3);
}
button.t-red .t-icon  { color: #ff0044; text-shadow: 0 0 8px rgba(255,0,68,0.9); }
button.t-red .t-label { color: rgba(255,0,68,0.9); }

button.t-yel {
  background:  rgba(255,224,0,0.09);
  border-color:rgba(255,224,0,0.35);
  box-shadow:  0 0 8px rgba(255,224,0,0.09), inset 0 1px 0 rgba(255,224,0,0.3);
}
button.t-yel .t-icon  { color: #ffe000; text-shadow: 0 0 8px rgba(255,224,0,0.9); }
button.t-yel .t-label { color: rgba(255,224,0,0.9); }

/* SLIDERS */
.sliders-section { padding: 3px 14px 9px; }
.sl-icon {
  font-size: 14px; min-width: 16px;
  background: transparent; border: none; padding: 0;
}
.sl-icon.sl-bright { color: #ffe000; }
.sl-icon.sl-vol    { color: #00ff41; }
.sl-icon.sl-mic    { color: #ff0044; }
.sl-val {
  font-size: 9px; font-weight: 600;
  color: rgba(255,255,255,0.6); min-width: 32px; letter-spacing: 1px;
}

scale { min-width: 80px; }
scale trough {
  background: rgba(255,255,255,0.06); border: none; border-radius: 3px; min-height: 5px;
}
scale highlight { border-radius: 3px; min-height: 5px; }
scale slider {
  min-width: 12px; min-height: 12px; border-radius: 50%; margin: -4px 0;
  background: rgba(255,255,255,0.9); border: none; box-shadow: 0 1px 5px rgba(0,0,0,0.8);
}
.sl-bright-track highlight { background: #ffe000; box-shadow: 0 0 6px rgba(255,224,0,0.6); }
.sl-vol-track    highlight { background: #00ff41; box-shadow: 0 0 6px rgba(0,255,65,0.6); }
.sl-mic-track    highlight { background: #ff0044; box-shadow: 0 0 5px rgba(255,0,68,0.5); }

/* VITALS */
.vitals-row { padding: 4px 10px 8px; }
.vital-box {
  background: rgba(255,255,255,0.022);
  border: 1px solid rgba(255,255,255,0.055);
  padding: 7px 6px 8px;
}
.vital-label { font-size: 7px; font-weight: 600; color: rgba(255,255,255,0.5); letter-spacing: 2px; margin-bottom: 2px; }
.vital-val   { font-size: 15px; font-weight: 700; }
.v-cyan   { color: #00ff41; text-shadow: 0 0 10px rgba(0,255,65,0.65); }
.v-purple { color: #cc44ff; text-shadow: 0 0 10px rgba(204,68,255,0.65); }
.v-red    { color: #ff0044; text-shadow: 0 0 10px rgba(255,0,68,0.65); }
.v-yellow { color: #ffe000; text-shadow: 0 0 10px rgba(255,224,0,0.65); }
.v-green  { color: #00ff41; }

.vital-bar { min-width: 40px; }
.vital-bar trough { background: rgba(255,255,255,0.06); border: none; border-radius: 1px; min-height: 3px; }
.vital-bar highlight { border-radius: 1px; min-height: 3px; }
.vital-bar slider { min-width: 0; min-height: 0; background: transparent; border: none; margin: 0; padding: 0; }
.vb-cyan   highlight { background: #00ff41; box-shadow: 0 0 5px rgba(0,255,65,0.8); }
.vb-purple highlight { background: #cc44ff; box-shadow: 0 0 5px rgba(204,68,255,0.8); }
.vb-red    highlight { background: #ff0044; box-shadow: 0 0 5px rgba(255,0,68,0.8); }
.vb-yellow highlight { background: #ffe000; box-shadow: 0 0 5px rgba(255,224,0,0.8); }

/* APPS */
.apps-row { padding: 4px 10px 8px; }
button.app-btn {
  background: rgba(255,255,255,0.022);
  border:     1px solid rgba(255,255,255,0.055);
  color:      rgba(255,255,255,0.45);
  font-size:  15px;
  padding:    8px 2px;
}
button.app-btn:hover {
  background:  rgba(0,255,65,0.09);
  border-color:rgba(0,255,65,0.3);
  color:       #00ff41;
  box-shadow:  0 0 12px rgba(0,255,65,0.18);
}

/* FOOTER */
.cc-footer {
  padding:    5px 14px 9px;
  border-top: 1px solid rgba(0,255,65,0.08);
  background: rgba(0,255,65,0.02);
}
.footer-wifi { font-size: 8px; font-weight: 600; color: rgba(0,255,65,0.6); letter-spacing: 1px; }
.footer-bat  { font-size: 8px; font-weight: 600; color: rgba(255,224,0,0.75); letter-spacing: 1px; }
